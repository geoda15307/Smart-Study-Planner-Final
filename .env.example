NEXT_PUBLIC_APP_NAME="Smart Study Planner"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Jangan expose API key di frontend (semua ini server-only, lihat docs/15_SECURITY.md)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Provider Gemini sungguhan sudah diimplementasikan (Milestone C). Isi GEMINI_API_KEY di
# .env.local untuk memakainya. GEMINI_MODEL opsional (default gemini-flash-latest, alias
# selalu-terkini) — override kalau butuh model spesifik (mis. gemini-3.5-flash).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"
AI_PROVIDER="mock"
# Batas jumlah panggilan AI per user per hari (Cost Control, Milestone D). Dihitung di tabel
# Supabase ai_usage_log. Default 50 kalau tidak diisi. Tiap chunk dokumen panjang dihitung 1.
AI_DAILY_REQUEST_LIMIT="50"

OCR_PROVIDER="ocrspace"
OCR_SPACE_API_KEY=""

NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
